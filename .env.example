# Copy to .env and adjust for your LAN environment

NODE_ENV=development
PORT=3443

# Shared Postgres (LAN) — prefer DB_* (used by the server)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nsc_erms
DB_USER=postgres
DB_PASSWORD=change_me

# Optional alternative to DB_* :
# DATABASE_URL=postgresql://postgres:change_me@127.0.0.1:5432/nsc_erms

# Session
SESSION_SECRET=change-me-to-a-long-random-string

# TLS (LAN HTTPS) — paths to cert/key; leave empty to run HTTP in local dev only
TLS_CERT_PATH=
TLS_KEY_PATH=

# File storage (absolute path recommended)
FILES_ROOT=C:\nsc-erms-files
MAX_UPLOAD_BYTES=31457280

# Backup archives (pg_dump + FILES_ROOT zip). Default: <project>/backups
BACKUPS_ROOT=
# Optional full path to pg_dump if not on PATH (e.g. C:\Program Files\PostgreSQL\18\bin\pg_dump.exe)
PG_DUMP_PATH=

# Optional: LibreOffice soffice for Excel→PDF PDS preview (e.g. C:\Program Files\LibreOffice\program\soffice.exe)
SOFFICE_PATH=

# Scan-to-folder inbox (defaults to FILES_ROOT/inbox if empty)
SCAN_INBOX_PATH=

# Superadmin seed (created by npm run seed)
SEED_SUPERADMIN_USERNAME=superadmin
SEED_SUPERADMIN_PASSWORD=ChangeMeNow!
SEED_SUPERADMIN_DISPLAY_NAME=System Superadmin

# Optional: allow HTTP in development when TLS paths are empty
ALLOW_HTTP_DEV=true

# Comma-separated browser origins for CORS (required for Vite dev on :5173 in production).
# Same-origin deploy (npm start) usually needs no entries. Example:
# CORS_ORIGINS=http://localhost:5173,https://erms.local:3443
CORS_ORIGINS=
