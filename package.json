{
  "name": "nsc-erms",
  "version": "0.1.0",
  "author": "Northern Samar Colleges",
  "private": true,
  "description": "Northern Samar Colleges — Employee Records Management System",
  "main": "electron/main.js",
  "workspaces": [
    "renderer",
    "server"
  ],
  "scripts": {
    "dev:client": "npm run dev -w renderer",
    "dev:server": "npm run dev -w server",
    "dev": "npm run dev:server",
    "dev:desktop": "electron .",
    "build": "npm run build -w renderer",
    "build:desktop": "electron-builder --win nsis",
    "start": "npm run start -w server",
    "start:fresh": "npm run build && npm run start",
    "migrate": "npm run migrate -w server",
    "seed": "npm run seed -w server",
    "seed:employees": "npm run seed:employees -w server",
    "seed:pds-demo": "npm run seed:pds-demo -w server",
    "verify:pds-excel": "npm run verify:pds-excel -w server",
    "db:create": "npm run db:create -w server",
    "db:setup": "npm run db:create && npm run migrate && npm run seed"
  },
  "build": {
    "appId": "ph.edu.nsc.erms",
    "productName": "NSC-ERMS",
    "copyright": "Copyright © Northern Samar Colleges",
    "directories": {
      "output": "dist/desktop",
      "buildResources": "electron/assets"
    },
    "files": [
      "electron/**/*",
      "!electron/config.json",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "electron/config.example.json",
        "to": "config.example.json"
      }
    ],
    "win": {
      "icon": "electron/assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NSC-ERMS"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  }
}
